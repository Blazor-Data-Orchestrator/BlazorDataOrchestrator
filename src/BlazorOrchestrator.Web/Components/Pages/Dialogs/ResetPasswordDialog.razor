@using Radzen
@using Radzen.Blazor

<RadzenStack Gap="1rem" Style="min-width: 420px;">
    <RadzenText TextStyle="TextStyle.Body2">
        Set a new local password for <strong>@Email</strong>, or clear it so the user can
        sign in only with an external provider.
    </RadzenText>

    <RadzenStack Gap="0.25rem">
        <RadzenLabel Text="New password" Component="newPassword" Style="font-weight: 500;" />
        <RadzenPassword @bind-Value="_password" Name="newPassword" Style="width: 100%;" />
        <RadzenText TextStyle="TextStyle.Caption" Style="color: #6b7280; margin: 0;">
            Min 12 chars, mixed case, digit + symbol. Leave blank and click "Clear password" to remove.
        </RadzenText>
    </RadzenStack>

    @if (!string.IsNullOrEmpty(_errorMessage))
    {
        <RadzenAlert AlertStyle="AlertStyle.Danger" AllowClose="false" ShowIcon="true">
            @_errorMessage
        </RadzenAlert>
    }

    <RadzenStack Orientation="Orientation.Horizontal" Gap="0.5rem" JustifyContent="JustifyContent.SpaceBetween">
        <RadzenButton Text="Clear password" Icon="lock_open" ButtonStyle="ButtonStyle.Danger"
                      Variant="Variant.Outlined" Click="@ClearAsync" Disabled="@_isSaving" />
        <RadzenStack Orientation="Orientation.Horizontal" Gap="0.5rem">
            <RadzenButton Text="Cancel" ButtonStyle="ButtonStyle.Light" Variant="Variant.Outlined"
                          Click="@(() => DialogService.Close())" Disabled="@_isSaving" />
            <RadzenButton Text="Save" ButtonStyle="ButtonStyle.Success" Icon="save"
                          Click="@SaveAsync" Disabled="@_isSaving" />
        </RadzenStack>
    </RadzenStack>
</RadzenStack>

@code {
    [Inject] DialogService DialogService { get; set; } = default!;
    [Inject] AllowedUserService Users { get; set; } = default!;
    [Inject] NotificationService Notify { get; set; } = default!;

    [Parameter] public string UserId { get; set; } = string.Empty;
    [Parameter] public string Email { get; set; } = string.Empty;

    private string _password = string.Empty;
    private string _errorMessage = string.Empty;
    private bool _isSaving;

    private async Task SaveAsync()
    {
        _errorMessage = string.Empty;
        if (string.IsNullOrWhiteSpace(_password))
        {
            _errorMessage = "Enter a password or use Clear password.";
            return;
        }

        _isSaving = true;
        try
        {
            await Users.SetPasswordAsync(UserId, _password);
            Notify.Notify(NotificationSeverity.Success, "Password updated");
            DialogService.Close(true);
        }
        catch (Exception ex)
        {
            _errorMessage = ex.Message;
        }
        finally
        {
            _isSaving = false;
        }
    }

    private async Task ClearAsync()
    {
        var confirmed = await DialogService.Confirm(
            "Remove the local password for this user? They will only be able to log in with an external provider.",
            "Clear password");
        if (confirmed != true) return;

        _isSaving = true;
        try
        {
            await Users.SetPasswordAsync(UserId, null);
            Notify.Notify(NotificationSeverity.Success, "Password cleared");
            DialogService.Close(true);
        }
        catch (Exception ex)
        {
            _errorMessage = ex.Message;
        }
        finally
        {
            _isSaving = false;
        }
    }
}
